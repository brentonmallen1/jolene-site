# Copy to .env and adjust. Every value has a safe default — you only need a
# .env at all if a default clashes with something else on your machine.

# Port the dev server (hot reload) is exposed on: just dev → http://localhost:$DEV_PORT
DEV_PORT=4321

# Port the production preview (nginx) is exposed on: just preview → http://localhost:$PREVIEW_PORT
PREVIEW_PORT=8080

# Canonical site URL baked into the build (sitemap, og tags)
SITE_URL=https://www.jolenemallendesigns.com

# Prefix for container/volume names so this project never collides with others
COMPOSE_PROJECT_NAME=jolene-site
