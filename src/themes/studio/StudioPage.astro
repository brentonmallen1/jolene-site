---
import "@fontsource-variable/fraunces/index.css";
import { Image } from "astro:assets";
import Footer from "../../components/Footer.astro";
import GalleryGrid from "../../components/GalleryGrid.astro";
import ThemeToggle from "../../components/ThemeToggle.astro";

const { site } = Astro.props;
const { settings, sections } = site;

const num = (i: number) => String(i + 1).padStart(2, "0");

// hero heading is stored uppercase for the classic theme; the serif cover wants Title Case
const titleCase = (s: string) =>
  s.toLowerCase().replace(/(^|\s)\S/g, (c: string) => c.toUpperCase());
---

<div id="top"></div>

<!-- rail on desktop, numeral strip on mobile -->
<nav class="rail" aria-label="Sections">
  <a class="rail-brand" href="#top" aria-label="Back to top">JM</a>
  <ul>
    {sections.map((s: any, i: number) => (
      <li>
        <a href={`#${s.id}`} data-nav-link={s.id}>
          <span class="rail-num">{num(i)}</span>
          <span class="rail-label">{s.title}</span>
        </a>
      </li>
    ))}
  </ul>
  <div class="rail-toggle"><ThemeToggle /></div>
</nav>

<main id="main" class="studio">
  <!-- Cover -->
  <header class="cover">
    <div class="cover-type" data-reveal>
      <p class="caps-label cover-kicker">Portfolio — North Carolina</p>
      <h1 class="cover-name">{titleCase(settings.hero.heading)}</h1>
      <p class="cover-role">{titleCase(settings.hero.subheading)}</p>
    </div>
    <figure class="cover-art" data-reveal>
      <Image
        src={settings.hero.image}
        alt={settings.hero.image_alt}
        widths={[700, 1100, 1600]}
        sizes="(min-width: 64rem) 52vw, 94vw"
        loading="eager"
        fetchpriority="high"
      />
    </figure>
    <ol class="cover-index" aria-label="Contents">
      {sections.map((s: any, i: number) => (
        <li>
          <a href={`#${s.id}`}>
            <span class="idx-num">{num(i)}</span>
            <span class="idx-label">{s.title}</span>
          </a>
        </li>
      ))}
    </ol>
  </header>

  {sections.map((section: any, i: number) => {
    const AboutBody = section.type === "about" ? section.data.Content : null;
    return (
    <section id={section.id} class="panel">
      <span class="ghost" aria-hidden="true">{num(i)}</span>
      <h2 class="panel-title" data-reveal>{section.title}</h2>

      {section.type === "about" && (
        <div class="about-cols">
          <figure class="about-photo" data-reveal>
            <Image
              src={section.data.headshot}
              alt={section.data.headshot_alt}
              widths={[400, 700, 1000]}
              sizes="(min-width: 64rem) 34vw, (min-width: 40rem) 45vw, 92vw"
            />
          </figure>
          <div class="prose" data-reveal>
            <AboutBody />
            {section.data.badges.length > 0 && (
              <div class="badges">
                {section.data.badges.map((b: any) => (
                  <Image src={b.image} alt={b.alt} width={100} densities={[1, 2]} />
                ))}
              </div>
            )}
          </div>
        </div>
      )}

      {section.type === "gallery" && (
        <>
          <GalleryGrid id={section.id} items={section.data.gallery} variant={section.data.layout} />
          {section.data.notes.map((n: string) => (
            <p class="panel-note">{n}</p>
          ))}
        </>
      )}

      {section.type === "conceptual" && (
        <div class="case-list">
          {section.data.map((p: any) => {
            const Body = p.Content;
            return (
              <article class="case">
                <div class="case-text">
                  <p class="caps-label">{p.label}</p>
                  <h3 class="case-title" data-reveal>{p.title}</h3>
                  <p class="case-brief">{p.brief}</p>
                  <div class="prose case-body">
                    <Body />
                  </div>
                </div>
                <div class="case-gallery">
                  <GalleryGrid id={`conceptual-${p.slug}`} items={p.gallery} variant={p.layout} />
                </div>
              </article>
            );
          })}
        </div>
      )}

      {section.type === "textiles" && (
        <div class="patterns">
          {section.data.map((t: any) => (
            <div class="pattern">
              <h3 class="pattern-title" data-reveal>
                {t.name}
                <span class="pattern-inspo">inspired by {t.inspiration}</span>
              </h3>
              <GalleryGrid
                id={`textiles-${t.name.toLowerCase()}`}
                items={t.swatches.map((sw: any) => ({
                  image: sw.image,
                  alt: `${t.name} — ${sw.colorway}`,
                  caption: sw.colorway,
                }))}
                variant="squares"
              />
            </div>
          ))}
        </div>
      )}

      {section.type === "resume" && (
        <>
          <object
            class="resume-embed"
            data={section.data.pdf}
            type="application/pdf"
            aria-label="Resume PDF"
          >
            <p class="panel-note">
              Your browser can’t display the PDF inline —
              <a href={section.data.pdf} target="_blank" rel="noreferrer">open the resume</a> instead.
            </p>
          </object>
          <a class="resume-link" href={section.data.pdf} target="_blank" rel="noreferrer">
            View resume (PDF)
          </a>
        </>
      )}
    </section>
    );
  })}

  <Footer email={settings.footer.email} linkedin={settings.footer.linkedin} name={settings.hero.heading} />
</main>

<script>
  import "../../scripts/reveal.ts";

  // current-section highlight on the rail
  const links = new Map(
    [...document.querySelectorAll<HTMLAnchorElement>("[data-nav-link]")].map((a) => [
      a.dataset.navLink!,
      a,
    ])
  );
  const io = new IntersectionObserver(
    (entries) => {
      for (const e of entries) {
        const link = links.get(e.target.id);
        if (link && e.isIntersecting) {
          links.forEach((a) => a.removeAttribute("aria-current"));
          link.setAttribute("aria-current", "true");
        }
      }
    },
    { rootMargin: "-40% 0px -55% 0px" }
  );
  links.forEach((_, id) => {
    const el = document.getElementById(id);
    if (el) io.observe(el);
  });
</script>

<style>
  .studio {
    --display: "Fraunces Variable", Georgia, serif;
  }

  /* ------------------------------------------------------------- rail --- */
  .rail {
    position: fixed;
    z-index: 20;
    inset: 0 auto 0 0;
    inline-size: 4.25rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    border-inline-end: 1px solid var(--line);
    background: var(--paper);
    padding-block: var(--space-sm);
  }
  .rail-brand {
    font-family: "Fraunces Variable", Georgia, serif;
    font-size: 1.3rem;
    font-weight: 550;
    text-decoration: none;
  }
  .rail ul {
    list-style: none;
    padding: 0;
    margin-block: auto;
    display: grid;
    gap: 0.4rem;
  }
  .rail a:not(.rail-brand) {
    position: relative;
    display: grid;
    place-items: center;
    inline-size: 2.6rem;
    block-size: 2.6rem;
    text-decoration: none;
    color: var(--muted);
    font-size: var(--text-xs);
    letter-spacing: 0.1em;
    border: 1px solid transparent;
    transition: color var(--dur-fast) ease, border-color var(--dur-fast) ease;
  }
  .rail a:not(.rail-brand):hover,
  .rail a[aria-current="true"] {
    color: var(--ink);
    border-color: var(--accent);
  }
  .rail-label {
    position: absolute;
    inset-inline-start: calc(100% + 0.6rem);
    padding: 0.3em 0.7em;
    background: var(--ink);
    color: var(--paper);
    font-size: var(--text-xs);
    letter-spacing: var(--track-caps);
    text-transform: uppercase;
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--dur-fast) ease;
  }
  .rail a:hover .rail-label,
  .rail a:focus-visible .rail-label {
    opacity: 1;
  }

  .studio {
    margin-inline-start: 4.25rem;
  }

  @media (max-width: 63.9rem) {
    .rail {
      inset: 0 0 auto 0;
      inline-size: auto;
      block-size: 3.4rem;
      flex-direction: row;
      border-inline-end: none;
      border-block-end: 1px solid var(--line);
      padding: 0 var(--gutter);
      gap: 0.75rem;
    }
    .rail ul {
      display: flex;
      margin-inline: auto;
      gap: 0;
      overflow-x: auto;
      scrollbar-width: none; /* sections beyond ~6 scroll instead of clipping */
    }
    .rail a:not(.rail-brand) {
      inline-size: 2.3rem;
      block-size: 2.3rem;
    }
    .rail-label {
      display: none;
    }
    .studio {
      margin-inline-start: 0;
      padding-block-start: 3.4rem;
    }
  }

  /* ------------------------------------------------------------ cover --- */
  .cover {
    position: relative;
    display: grid;
    align-content: center;
    gap: var(--space-lg);
    min-block-size: 100svh;
    padding: var(--space-lg) var(--gutter);
    overflow: hidden;
  }
  @media (min-width: 64rem) {
    .cover {
      grid-template-columns: minmax(24rem, 1fr) minmax(0, 1.1fr);
      grid-template-areas: "type art" "index art";
      align-items: end;
      column-gap: var(--space-lg);
    }
    .cover-type { grid-area: type; align-self: center; }
    .cover-art { grid-area: art; }
    .cover-index { grid-area: index; }
  }
  .cover-kicker {
    margin-block-end: var(--space-sm);
  }
  .cover-name {
    font-family: var(--display);
    font-size: var(--text-2xl);
    font-weight: 380;
    font-variation-settings: "opsz" 120;
    line-height: 1.02;
    letter-spacing: -0.01em;
    max-inline-size: 8em;
  }
  .cover-role {
    margin-block-start: var(--space-sm);
    font-size: var(--text-md);
    font-family: var(--display);
    font-style: italic;
    font-weight: 340;
    color: var(--accent);
  }
  .cover-art {
    margin: 0;
    position: relative;
  }
  .cover-art :global(img) {
    inline-size: 100%;
    max-block-size: 74vh;
    object-fit: cover;
  }
  .cover-art::after {
    content: "";
    position: absolute;
    inset: var(--space-xs) calc(var(--space-xs) * -1) calc(var(--space-xs) * -1) var(--space-xs);
    border: 1px solid var(--accent);
    pointer-events: none;
  }
  .cover-index {
    list-style: none;
    padding: 0;
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem var(--space-md);
    border-block-start: 1px solid var(--line);
    padding-block-start: var(--space-sm);
  }
  .cover-index a {
    display: flex;
    gap: 0.6em;
    align-items: baseline;
    text-decoration: none;
    padding-block: 0.3em;
  }
  .idx-num {
    font-size: var(--text-xs);
    color: var(--accent);
    letter-spacing: 0.1em;
  }
  .idx-label {
    font-size: var(--text-sm);
    letter-spacing: var(--track-caps);
    text-transform: uppercase;
    color: var(--muted);
    transition: color var(--dur-fast) ease;
  }
  .cover-index a:hover .idx-label {
    color: var(--ink);
  }

  /* ----------------------------------------------------------- panels --- */
  .panel {
    position: relative;
    padding: var(--space-xl) var(--gutter);
    max-inline-size: calc(var(--content-max) + 8rem);
    margin-inline: auto;
    scroll-margin-block-start: 3.4rem;
  }
  .panel + .panel {
    border-block-start: 1px solid var(--line);
  }
  .ghost {
    position: absolute;
    top: 0.05em;
    inset-inline-end: var(--gutter);
    font-family: var(--display);
    font-size: clamp(6rem, 18vw, 15rem);
    font-weight: 300;
    line-height: 1;
    color: var(--wash);
    z-index: -1;
    user-select: none;
  }
  .panel-title {
    font-family: var(--display);
    font-size: var(--text-xl);
    font-weight: 400;
    font-variation-settings: "opsz" 90;
    margin-block-end: var(--space-lg);
  }
  .panel-note {
    margin-block-start: var(--space-md);
    font-size: var(--text-xs);
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  /* about */
  .about-cols {
    display: grid;
    gap: var(--space-lg);
    align-items: start;
  }
  @media (min-width: 48rem) {
    .about-cols {
      grid-template-columns: minmax(15rem, 2fr) 3fr;
    }
    .about-photo {
      position: sticky;
      top: var(--space-lg);
    }
  }
  .about-photo {
    margin: 0;
    position: relative;
  }
  .about-photo::after {
    content: "";
    position: absolute;
    inset: var(--space-xs) calc(var(--space-xs) * -1) calc(var(--space-xs) * -1) var(--space-xs);
    border: 1px solid var(--line);
    pointer-events: none;
  }
  .badges {
    margin-block-start: var(--space-md);
    display: flex;
    gap: var(--space-sm);
  }
  .prose > :global(p) {
    max-inline-size: var(--prose-max);
  }
  .prose :global(p + p) {
    margin-block-start: 1em;
  }

  /* conceptual cases */
  .case-list {
    display: grid;
    gap: var(--space-xl);
  }
  .case {
    display: grid;
    gap: var(--space-lg);
  }
  @media (min-width: 64rem) {
    .case {
      grid-template-columns: minmax(18rem, 2fr) 3fr;
      align-items: start;
    }
    .case-text {
      position: sticky;
      top: var(--space-lg);
    }
  }
  .case-title {
    font-family: var(--display);
    font-size: var(--text-xl);
    font-weight: 420;
    line-height: 1.1;
    margin-block: 0.2em 0.5em;
  }
  .case-brief {
    font-size: var(--text-md);
    line-height: 1.5;
    color: var(--muted);
  }
  .case-body {
    margin-block-start: var(--space-md);
    font-size: var(--text-sm);
  }

  /* textiles */
  .patterns {
    display: grid;
    gap: var(--space-lg);
  }
  .pattern-title {
    font-family: var(--display);
    font-size: var(--text-lg);
    font-weight: 420;
    margin-block-end: var(--space-sm);
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.4em 1em;
  }
  .pattern-inspo {
    font-style: italic;
    font-weight: 340;
    font-size: var(--text-md);
    color: var(--accent);
  }

  /* resume */
  .resume-embed {
    display: block;
    inline-size: 100%;
    max-inline-size: 54rem;
    margin-inline: auto;
    aspect-ratio: 8.5 / 11;
    max-block-size: 85vh;
    border: 1px solid var(--line);
    background: var(--paper);
  }
  .resume-link {
    display: none;
  }
  @media (max-width: 40rem) {
    .resume-embed {
      display: none;
    }
    .resume-link {
      display: inline-block;
      padding: 0.8em 1.8em;
      border: 1px solid var(--ink);
      font-size: var(--text-xs);
      font-weight: 500;
      letter-spacing: var(--track-caps);
      text-transform: uppercase;
      text-decoration: none;
    }
  }

  /* reveal */
  [data-reveal] {
    opacity: 0;
    translate: 0 16px;
    transition: opacity var(--dur-slow) var(--ease-out), translate var(--dur-slow) var(--ease-out);
  }
  [data-reveal].in-view {
    opacity: 1;
    translate: 0 0;
  }
</style>
