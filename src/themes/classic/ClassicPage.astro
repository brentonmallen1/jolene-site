---
import { Image } from "astro:assets";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import SectionHeading from "../../components/SectionHeading.astro";
import GalleryGrid from "../../components/GalleryGrid.astro";

const { site } = Astro.props;
const { settings, sections } = site;

const num = (i: number) => String(i + 1).padStart(2, "0");
const navSections = sections.map((s: any) => ({ id: s.id, label: s.title }));
---

<div id="top"></div>
<Nav brand={settings.hero.heading} sections={navSections} />

<main id="main">
  <!-- Hero -->
  <section class="hero">
    <Image
      src={settings.hero.image}
      alt={settings.hero.image_alt}
      widths={[800, 1400, 2200]}
      sizes="100vw"
      loading="eager"
      fetchpriority="high"
      class="hero-img"
    />
    <div class="hero-title">
      <div class="hero-plate">
        <h1>{settings.hero.heading}</h1>
        <p class="caps-label hero-sub">{settings.hero.subheading}</p>
      </div>
    </div>
  </section>

  {sections.map((section: any, i: number) => {
    const AboutBody = section.type === "about" ? section.data.Content : null;
    return (
    <section id={section.id} class:list={["section", { "section--wash": i % 2 === 1 }]}>
      <div class="container">
        <SectionHeading number={num(i)} title={section.title} />

        {section.type === "about" && (
          <div class="about-grid">
            <div class="about-photo" data-reveal>
              <Image
                src={section.data.headshot}
                alt={section.data.headshot_alt}
                widths={[400, 700, 1000]}
                sizes="(min-width: 64rem) 380px, (min-width: 40rem) 45vw, 92vw"
              />
            </div>
            <div class="about-text prose">
              <AboutBody />
              {section.data.badges.length > 0 && (
                <div class="badges">
                  {section.data.badges.map((b: any) => (
                    <Image src={b.image} alt={b.alt} width={110} densities={[1, 2]} />
                  ))}
                </div>
              )}
            </div>
          </div>
        )}

        {section.type === "gallery" && (
          <>
            <GalleryGrid id={section.id} items={section.data.gallery} variant={section.data.layout} />
            {section.data.notes.map((n: string) => (
              <p class="section-note">{n}</p>
            ))}
          </>
        )}

        {section.type === "conceptual" && (
          <div class="projects">
            {section.data.map((p: any) => {
              const Body = p.Content;
              return (
                <article class="project">
                  <header class="project-head" data-reveal>
                    <p class="caps-label">{p.label}</p>
                    <h3 class="project-title">{p.title}</h3>
                    <p class="project-brief">{p.brief}</p>
                  </header>
                  <div class="prose project-body">
                    <Body />
                  </div>
                  <GalleryGrid id={`conceptual-${p.slug}`} items={p.gallery} variant={p.layout} />
                </article>
              );
            })}
          </div>
        )}

        {section.type === "textiles" && (
          <div class="patterns">
            {section.data.map((t: any) => (
              <div class="pattern">
                <p class="pattern-head" data-reveal>
                  <span class="pattern-name">Pattern: {t.name}</span>
                  <span class="pattern-inspo">Inspired by {t.inspiration}</span>
                </p>
                <GalleryGrid
                  id={`textiles-${t.name.toLowerCase()}`}
                  items={t.swatches.map((sw: any) => ({
                    image: sw.image,
                    alt: `${t.name} — ${sw.colorway}`,
                    caption: sw.colorway,
                  }))}
                  variant="squares"
                />
              </div>
            ))}
          </div>
        )}

        {section.type === "resume" && (
          <>
            <object
              class="resume-embed"
              data={section.data.pdf}
              type="application/pdf"
              aria-label="Resume PDF"
            >
              <p class="section-note">
                Your browser can’t display the PDF inline —
                <a href={section.data.pdf} target="_blank" rel="noreferrer">open the resume</a> instead.
              </p>
            </object>
            <a class="resume-link" href={section.data.pdf} target="_blank" rel="noreferrer">
              View resume (PDF)
            </a>
          </>
        )}
      </div>
    </section>
    );
  })}
</main>

<Footer email={settings.footer.email} linkedin={settings.footer.linkedin} name={settings.hero.heading} />

<script>
  import "../../scripts/reveal.ts";
</script>

<style>
  .container {
    max-inline-size: var(--content-max);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }
  .section {
    padding-block: var(--space-xl);
    scroll-margin-block-start: 3.75rem;
  }
  .section--wash {
    background: var(--wash);
  }
  .section-note {
    margin-block-start: var(--space-md);
    font-size: var(--text-xs);
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  /* hero — full image shown at page width, no cropping */
  .hero {
    position: relative;
  }
  .hero :global(.hero-img) {
    inline-size: 100%;
    block-size: auto;
    display: block;
  }
  .hero-title {
    position: absolute;
    inset: 0;
    display: grid;
    place-content: center;
    text-align: center;
  }
  .hero-plate {
    padding: clamp(1.25rem, 3vw, 3rem) clamp(1.5rem, 5vw, 4.5rem);
    background: color-mix(in oklab, var(--paper) 78%, transparent);
    backdrop-filter: blur(4px);
    border-block-start: 1px solid var(--accent);
    border-block-end: 1px solid var(--accent-2);
  }
  @media (max-width: 40rem) {
    /* wide image gets short on phones — set the title below it instead */
    .hero-title {
      position: static;
      padding-block: var(--space-md) var(--space-2xs);
    }
    .hero-plate {
      background: none;
      backdrop-filter: none;
      padding: 0;
      border: none;
    }
  }
  .hero-title h1 {
    font-size: var(--text-hero);
    font-weight: 340;
    letter-spacing: var(--track-wide);
    text-transform: uppercase;
    line-height: 1.08;
    text-indent: var(--track-wide); /* optically re-center tracked caps */
  }
  .hero-sub {
    margin-block-start: 0.6rem;
    color: var(--accent);
    letter-spacing: calc(var(--track-wide) * 1.6);
    text-indent: calc(var(--track-wide) * 1.6);
  }

  /* about */
  .about-grid {
    display: grid;
    gap: var(--space-lg);
    align-items: start;
  }
  @media (min-width: 48rem) {
    .about-grid {
      grid-template-columns: minmax(16rem, 2fr) 3fr;
    }
  }
  .about-photo :global(img) {
    inline-size: 100%;
  }
  .badges {
    margin-block-start: var(--space-md);
    display: flex;
    gap: var(--space-sm);
    align-items: center;
  }

  /* prose */
  .prose > :global(p) {
    max-inline-size: var(--prose-max);
  }
  .prose :global(p + p) {
    margin-block-start: 1em;
  }

  /* conceptual */
  .projects {
    display: grid;
    gap: var(--space-xl);
  }
  .project-head {
    max-inline-size: var(--prose-max);
  }
  .project-title {
    font-size: var(--text-xl);
    font-weight: 380;
    letter-spacing: 0.06em;
    margin-block: 0.25em 0.5em;
  }
  .project-brief {
    font-size: var(--text-md);
    line-height: 1.5;
    color: var(--muted);
  }
  .project-body {
    margin-block: var(--space-md);
  }

  /* textiles */
  .patterns {
    display: grid;
    gap: var(--space-lg);
  }
  .pattern-head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem 1.5rem;
    margin-block-end: var(--space-sm);
  }
  .pattern-name {
    font-size: var(--text-md);
    font-weight: 460;
    letter-spacing: var(--track-caps);
    text-transform: uppercase;
  }
  .pattern-inspo {
    font-size: var(--text-sm);
    color: var(--muted);
    letter-spacing: 0.08em;
  }

  /* resume */
  .resume-embed {
    display: block;
    inline-size: 100%;
    max-inline-size: 54rem;
    margin-inline: auto;
    aspect-ratio: 8.5 / 11;
    max-block-size: 85vh;
    border: 1px solid var(--line);
    background: var(--paper);
  }
  .resume-link {
    display: none;
  }
  @media (max-width: 40rem) {
    /* mobile browsers rarely render inline PDFs — swap the viewer for a link */
    .resume-embed {
      display: none;
    }
    .resume-link {
      display: inline-block;
      padding: 0.8em 1.8em;
      border: 1px solid var(--ink);
      font-size: var(--text-xs);
      font-weight: 500;
      letter-spacing: var(--track-caps);
      text-transform: uppercase;
      text-decoration: none;
    }
  }

  /* shared reveal for non-gallery elements */
  [data-reveal] {
    opacity: 0;
    translate: 0 14px;
    transition: opacity var(--dur-slow) var(--ease-out), translate var(--dur-slow) var(--ease-out);
  }
  [data-reveal].in-view {
    opacity: 1;
    translate: 0 0;
  }
</style>
