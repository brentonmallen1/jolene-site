---
import { Image } from "astro:assets";
import Nav from "../../components/Nav.astro";
import Footer from "../../components/Footer.astro";
import GalleryShelf from "../../components/GalleryShelf.astro";

const { site } = Astro.props;
const { settings, sections } = site;

const num = (i: number) => String(i + 1).padStart(2, "0");
const navSections = sections.map((s: any) => ({ id: s.id, label: s.title }));
---

<div id="top"></div>
<Nav brand={settings.hero.heading} sections={navSections} />

<main id="main">
  <!-- Entrance: the hero hangs as a matted, framed piece on a wash wall -->
  <section class="entrance">
    <div class="entrance-wall">
      <figure class="entrance-frame" data-reveal>
        <div class="entrance-mat">
          <Image
            src={settings.hero.image}
            alt={settings.hero.image_alt}
            widths={[800, 1400, 2200]}
            sizes="(min-width: 64rem) 58rem, 92vw"
            loading="eager"
            fetchpriority="high"
          />
        </div>
      </figure>
    </div>
    <header class="container entrance-label" data-reveal>
      <h1>{settings.hero.heading}</h1>
      <p class="caps-label entrance-sub">{settings.hero.subheading}</p>
    </header>
  </section>

  {sections.map((section: any, i: number) => {
    const AboutBody = section.type === "about" ? section.data.Content : null;
    return (
    <section id={section.id} class="panel">
      <header class="container placard" data-reveal>
        <span class="placard-num" aria-hidden="true">{num(i)}</span>
        <h2 class="placard-title">{section.title}</h2>
      </header>

      {section.type === "about" && (
        <div class="container about-grid">
          <figure class="about-frame" data-reveal>
            <div class="entrance-mat">
              <Image
                src={section.data.headshot}
                alt={section.data.headshot_alt}
                widths={[400, 700, 1000]}
                sizes="(min-width: 64rem) 380px, (min-width: 40rem) 45vw, 92vw"
              />
            </div>
          </figure>
          <div class="about-text prose">
            <AboutBody />
            {section.data.badges.length > 0 && (
              <div class="badges">
                {section.data.badges.map((b: any) => (
                  <Image src={b.image} alt={b.alt} width={110} densities={[1, 2]} />
                ))}
              </div>
            )}
          </div>
        </div>
      )}

      {section.type === "gallery" && (
        <>
          <div class="wall">
            <GalleryShelf id={section.id} items={section.data.gallery} label={section.title} />
          </div>
          {section.data.notes.length > 0 && (
            <div class="container">
              {section.data.notes.map((n: string) => (
                <p class="section-note">{n}</p>
              ))}
            </div>
          )}
        </>
      )}

      {section.type === "conceptual" &&
        section.data.map((p: any) => {
          const Body = p.Content;
          return (
            <article class="project">
              <div class="container">
                <header class="project-head" data-reveal>
                  <p class="caps-label project-kicker">{p.label}</p>
                  <h3 class="project-title">{p.title}</h3>
                  <p class="project-brief">{p.brief}</p>
                </header>
                <div class="prose project-body">
                  <Body />
                </div>
              </div>
              <div class="wall">
                <GalleryShelf id={`conceptual-${p.slug}`} items={p.gallery} label={p.title} />
              </div>
            </article>
          );
        })}

      {section.type === "textiles" &&
        section.data.map((t: any) => (
          <div class="pattern">
            <p class="container pattern-head" data-reveal>
              <span class="pattern-name">Pattern: {t.name}</span>
              <span class="pattern-inspo">Inspired by {t.inspiration}</span>
            </p>
            <div class="wall">
              <GalleryShelf
                id={`textiles-${t.name.toLowerCase()}`}
                items={t.swatches.map((sw: any) => ({
                  image: sw.image,
                  alt: `${t.name} — ${sw.colorway}`,
                  caption: sw.colorway,
                }))}
                label={`Pattern: ${t.name}`}
              />
            </div>
          </div>
        ))}

      {section.type === "resume" && (
        <div class="container">
          <object
            class="resume-embed"
            data={section.data.pdf}
            type="application/pdf"
            aria-label="Resume PDF"
          >
            <p class="section-note">
              Your browser can’t display the PDF inline —
              <a href={section.data.pdf} target="_blank" rel="noreferrer">open the resume</a> instead.
            </p>
          </object>
          <a class="resume-link" href={section.data.pdf} target="_blank" rel="noreferrer">
            View resume (PDF)
          </a>
        </div>
      )}
    </section>
    );
  })}
</main>

<Footer email={settings.footer.email} linkedin={settings.footer.linkedin} name={settings.hero.heading} />

<script>
  import "../../scripts/reveal.ts";
</script>

<style>
  .container {
    max-inline-size: var(--content-max);
    margin-inline: auto;
    padding-inline: var(--gutter);
  }

  /* entrance */
  .entrance-wall {
    background: var(--wash);
    border-block-end: 1px solid var(--line);
    padding: clamp(1.25rem, 3.5vw, 2.5rem) var(--gutter);
  }
  .entrance-frame {
    margin: 0 auto;
    max-inline-size: min(58rem, 100%);
  }
  .entrance-mat {
    background: var(--paper);
    padding: clamp(0.75rem, 2vw, 1.5rem);
    border: 1px solid var(--line);
    box-shadow: 0 12px 32px -12px color-mix(in oklab, var(--ink) 25%, transparent);
  }
  .entrance-mat :global(img) {
    inline-size: 100%;
    block-size: auto;
    outline: 1px solid color-mix(in oklab, var(--accent) 60%, var(--line));
    outline-offset: 5px;
  }
  .entrance-label {
    padding-block: var(--space-md) var(--space-xs);
    text-align: center;
  }
  .entrance-label h1 {
    font-size: var(--text-2xl);
    font-weight: 340;
    letter-spacing: var(--track-wide);
    text-indent: var(--track-wide);
    text-transform: uppercase;
    line-height: 1.1;
  }
  .entrance-sub {
    margin-block-start: 0.7rem;
    color: var(--accent);
    letter-spacing: calc(var(--track-wide) * 1.6);
    text-indent: calc(var(--track-wide) * 1.6);
  }

  /* panels + wall plaques */
  .panel {
    padding-block: var(--space-md) var(--space-lg);
    scroll-margin-block-start: 3.75rem;
  }
  .placard {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    margin-block-end: var(--space-sm);
  }
  .placard-num {
    display: grid;
    place-items: center;
    padding: 0.3em 0.55em;
    font-size: var(--text-md);
    font-weight: 380;
    line-height: 1;
    background: var(--accent);
    color: var(--paper);
  }
  .placard-title {
    font-size: var(--text-lg);
    font-weight: 420;
    letter-spacing: var(--track-caps);
    text-transform: uppercase;
  }
  .placard::after {
    content: "";
    flex: 1;
    block-size: 1px;
    background: linear-gradient(to right, var(--accent-2) 0 2.5rem, var(--line) 2.5rem);
  }

  /* the wash band a shelf hangs on */
  .wall {
    background: var(--wash);
    --shelf-fade: var(--wash);
    border-block: 1px solid var(--line);
    padding-block: var(--space-sm);
  }

  .section-note {
    margin-block-start: var(--space-md);
    font-size: var(--text-xs);
    color: var(--muted);
    letter-spacing: 0.04em;
  }

  /* about */
  .about-grid {
    display: grid;
    gap: var(--space-lg);
    align-items: start;
  }
  @media (min-width: 48rem) {
    .about-grid {
      grid-template-columns: minmax(16rem, 2fr) 3fr;
    }
  }
  .about-frame {
    margin: 0;
  }
  .about-frame :global(img) {
    inline-size: 100%;
  }
  .badges {
    margin-block-start: var(--space-md);
    display: flex;
    gap: var(--space-sm);
    align-items: center;
  }

  /* prose */
  .prose > :global(p) {
    max-inline-size: var(--prose-max);
  }
  .prose :global(p + p) {
    margin-block-start: 1em;
  }

  /* conceptual */
  .project + .project {
    margin-block-start: var(--space-lg);
  }
  .project-head {
    max-inline-size: var(--prose-max);
  }
  .project-kicker {
    color: var(--accent-2);
  }
  .project-title {
    font-size: var(--text-xl);
    font-weight: 380;
    letter-spacing: 0.06em;
    margin-block: 0.25em 0.5em;
  }
  .project-brief {
    font-size: var(--text-md);
    line-height: 1.5;
    color: var(--muted);
  }
  .project-body {
    margin-block: var(--space-md);
  }

  /* textiles */
  .pattern + .pattern {
    margin-block-start: var(--space-md);
  }
  .pattern-head {
    display: flex;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.5rem 1.5rem;
    margin-block-end: var(--space-sm);
  }
  .pattern-name {
    font-size: var(--text-md);
    font-weight: 460;
    letter-spacing: var(--track-caps);
    text-transform: uppercase;
  }
  .pattern-inspo {
    font-size: var(--text-sm);
    color: var(--accent-2);
    letter-spacing: 0.08em;
  }

  /* resume */
  .resume-embed {
    display: block;
    inline-size: 100%;
    max-inline-size: 54rem;
    margin-inline: auto;
    aspect-ratio: 8.5 / 11;
    max-block-size: 85vh;
    border: 1px solid var(--line);
    background: var(--paper);
  }
  .resume-link {
    display: none;
  }
  @media (max-width: 40rem) {
    /* mobile browsers rarely render inline PDFs — swap the viewer for a link */
    .resume-embed {
      display: none;
    }
    .resume-link {
      display: inline-block;
      padding: 0.8em 1.8em;
      border: 1px solid var(--ink);
      font-size: var(--text-xs);
      font-weight: 500;
      letter-spacing: var(--track-caps);
      text-transform: uppercase;
      text-decoration: none;
    }
  }

  /* shared reveal for non-shelf elements */
  [data-reveal] {
    opacity: 0;
    translate: 0 14px;
    transition: opacity var(--dur-slow) var(--ease-out), translate var(--dur-slow) var(--ease-out);
  }
  [data-reveal].in-view {
    opacity: 1;
    translate: 0 0;
  }
</style>
