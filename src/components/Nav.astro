---
import ThemeToggle from "./ThemeToggle.astro";

interface Props {
  brand: string;
  sections: { id: string; label: string }[];
}
const { brand, sections } = Astro.props;
---

<header class="site-nav">
  <div class="nav-inner">
    <a class="brand" href="#top">{brand}</a>
    <nav aria-label="Sections">
      <button
        class="menu-btn"
        type="button"
        aria-expanded="false"
        aria-controls="nav-menu"
        data-menu-btn
      >
        <span class="menu-line"></span>
        <span class="menu-line"></span>
        <span class="visually-hidden">Menu</span>
      </button>
      <ul class="nav-list" id="nav-menu" data-nav-list>
        {sections.map((s) => (
          <li><a href={`#${s.id}`} data-nav-link={s.id}>{s.label}</a></li>
        ))}
      </ul>
    </nav>
    <ThemeToggle />
  </div>
</header>

<style>
  .site-nav {
    position: sticky;
    top: 0;
    z-index: 20;
    background: color-mix(in oklab, var(--paper) 88%, transparent);
    backdrop-filter: blur(10px);
    border-block-end: 1px solid var(--line);
  }
  .nav-inner {
    max-inline-size: var(--content-max);
    margin-inline: auto;
    padding-inline: var(--gutter);
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    block-size: 3.75rem;
  }
  .brand {
    font-weight: 500;
    letter-spacing: var(--track-caps);
    text-transform: uppercase;
    font-size: var(--text-sm);
    text-decoration: none;
    margin-inline-end: auto;
    white-space: nowrap;
  }
  .nav-list {
    display: flex;
    gap: clamp(0.9rem, 2vw, 1.75rem);
    list-style: none;
    padding: 0;
  }
  .nav-list a {
    font-size: var(--text-xs);
    font-weight: 450;
    letter-spacing: var(--track-caps);
    text-transform: uppercase;
    text-decoration: none;
    color: var(--muted);
    padding-block: 0.4rem;
    border-block-end: 1px solid transparent;
    transition: color var(--dur-fast) ease, border-color var(--dur-fast) ease;
  }
  .nav-list a:hover,
  .nav-list a[aria-current="true"] {
    color: var(--ink);
    border-block-end-color: var(--accent);
  }
  .menu-btn {
    display: none;
  }

  @media (max-width: 47.9rem) {
    .menu-btn {
      display: grid;
      gap: 7px;
      padding: 0.7rem 0.35rem;
      order: 3;
    }
    .menu-line {
      inline-size: 1.4rem;
      block-size: 1.5px;
      background: var(--ink);
      transition: rotate var(--dur-fast) ease, translate var(--dur-fast) ease;
    }
    .menu-btn[aria-expanded="true"] .menu-line:first-child {
      rotate: 45deg;
      translate: 0 4.25px;
    }
    .menu-btn[aria-expanded="true"] .menu-line:last-child {
      rotate: -45deg;
      translate: 0 -4.25px;
    }
    .nav-list {
      position: fixed;
      inset: 3.75rem 0 auto 0;
      flex-direction: column;
      gap: 0;
      background: var(--paper);
      border-block-end: 1px solid var(--line);
      padding-block: var(--space-xs);
      display: none;
    }
    .nav-list.open {
      display: flex;
    }
    .nav-list a {
      display: block;
      padding: 0.85rem var(--gutter);
      font-size: var(--text-sm);
    }
  }
</style>

<script>
  const btn = document.querySelector<HTMLButtonElement>("[data-menu-btn]");
  const list = document.querySelector<HTMLElement>("[data-nav-list]");
  btn?.addEventListener("click", () => {
    const open = list?.classList.toggle("open");
    btn.setAttribute("aria-expanded", String(!!open));
  });
  list?.addEventListener("click", (e) => {
    if ((e.target as HTMLElement).tagName === "A") {
      list.classList.remove("open");
      btn?.setAttribute("aria-expanded", "false");
    }
  });

  // Highlight the section currently in view.
  const links = new Map(
    [...document.querySelectorAll<HTMLAnchorElement>("[data-nav-link]")].map((a) => [
      a.dataset.navLink!,
      a,
    ])
  );
  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        const link = links.get(entry.target.id);
        if (!link) continue;
        if (entry.isIntersecting) {
          links.forEach((a) => a.removeAttribute("aria-current"));
          link.setAttribute("aria-current", "true");
        }
      }
    },
    { rootMargin: "-40% 0px -55% 0px" }
  );
  links.forEach((_, id) => {
    const el = document.getElementById(id);
    if (el) observer.observe(el);
  });
</script>
