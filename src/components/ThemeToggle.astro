---
// Light/dark toggle. Mode is resolved pre-paint in Base.astro; this just flips it.
---

<button class="mode-toggle" type="button" aria-label="Switch color mode" data-mode-toggle>
  <svg class="icon-sun" aria-hidden="true" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round">
    <circle cx="12" cy="12" r="4.4" />
    <path d="M12 2.5v2.6M12 18.9v2.6M2.5 12h2.6M18.9 12h2.6M5 5l1.8 1.8M17.2 17.2 19 19M19 5l-1.8 1.8M6.8 17.2 5 19" />
  </svg>
  <svg class="icon-moon" aria-hidden="true" viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linejoin="round">
    <path d="M20 14.5A8.5 8.5 0 0 1 9.5 4a8.5 8.5 0 1 0 10.5 10.5Z" />
  </svg>
</button>

<style>
  .mode-toggle {
    display: grid;
    place-items: center;
    inline-size: 2.4rem;
    block-size: 2.4rem;
    border-radius: 50%;
    color: var(--muted);
    transition: color var(--dur-fast) ease, background-color var(--dur-fast) ease;
  }
  .mode-toggle:hover {
    color: var(--ink);
    background: var(--wash);
  }
  :global([data-mode="dark"]) .icon-sun,
  .icon-moon {
    display: none;
  }
  :global([data-mode="dark"]) .icon-moon {
    display: block;
  }
</style>

<script>
  document.querySelectorAll("[data-mode-toggle]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const root = document.documentElement;
      const next = root.dataset.mode === "dark" ? "light" : "dark";
      root.dataset.mode = next;
      try {
        localStorage.setItem("jmd-mode", next);
      } catch {}
    });
  });
</script>
