---
import { Image, getImage } from "astro:assets";
import type { ImageMetadata } from "astro";
import PanoramaViewer from "./PanoramaViewer.astro";
import Sphere360 from "./Sphere360.astro";

interface Item {
  image: ImageMetadata;
  alt: string;
  caption?: string;
  view?: "still" | "wide" | "360";
}
interface Props {
  id: string;
  items: Item[];
  variant?: "masonry" | "rows" | "mosaic" | "squares";
}
const { id, items, variant = "masonry" } = Astro.props;

// Pre-compute the large (lightbox) rendition for each item.
const LB_WIDTH = 1800;
const enriched = await Promise.all(
  items.map(async (item) => {
    const scale = Math.min(1, LB_WIDTH / item.image.width);
    const large = await getImage({
      src: item.image,
      width: Math.round(item.image.width * scale),
    });
    return {
      ...item,
      largeSrc: large.src,
      lbWidth: Math.round(item.image.width * scale),
      lbHeight: Math.round(item.image.height * scale),
    };
  })
);

const sizes =
  variant === "squares"
    ? "(min-width: 64rem) 220px, (min-width: 40rem) 30vw, 45vw"
    : variant === "mosaic"
      ? "(min-width: 64rem) 50vw, 92vw"
      : "(min-width: 64rem) 360px, (min-width: 40rem) 44vw, 92vw";
const widths = variant === "squares" ? [240, 480] : [420, 760, 1100];
---

{/* wide/interactive images are pulled out of the flow and shown separately below */}
<div class={`gallery gallery--${variant}`} data-pswp-gallery={id}>
  {enriched.filter((item) => !(item.view !== "still" && item.view && variant !== "squares")).map((item, i) => (
    <figure class="gallery-item" data-reveal style={`--stagger: ${(i % 9) * 45}ms; --ar: ${(item.image.width / item.image.height).toFixed(3)}`}>
      <a
        href={item.largeSrc}
        data-pswp-width={item.lbWidth}
        data-pswp-height={item.lbHeight}
        target="_blank"
        rel="noreferrer"
        aria-label={`View larger: ${item.alt}`}
      >
        <Image
          src={item.image}
          alt={item.alt}
          widths={widths}
          sizes={sizes}
          class={variant === "squares" ? "sq" : undefined}
          loading="lazy"
        />
      </a>
      {variant === "squares" && item.caption && (
        <figcaption class="swatch-name">{item.caption}</figcaption>
      )}
    </figure>
  ))}
</div>

{variant !== "squares" && enriched.some((item) => item.view === "wide" || item.view === "360") && (
  <div class="wide-views" data-pswp-gallery={`${id}-wide`}>
    <p class="caps-label wide-views-label" data-reveal>
      <span class="wide-views-rule" aria-hidden="true"></span>
      Interactive views
      <span class="wide-views-rule" aria-hidden="true"></span>
    </p>
    <div class="wide-views-grid">
      {enriched.filter((item) => item.view === "wide" || item.view === "360").map((item) =>
        item.view === "360" ? (
          <Sphere360 image={item.image} alt={item.alt} />
        ) : (
          <PanoramaViewer
            image={item.image}
            alt={item.alt}
            lightboxSrc={item.largeSrc}
            lightboxWidth={item.lbWidth}
            lightboxHeight={item.lbHeight}
          />
        )
      )}
    </div>
  </div>
)}

<style>
  .gallery--masonry {
    columns: 1;
    column-gap: var(--space-sm);
  }
  @media (min-width: 40rem) {
    .gallery--masonry {
      columns: 2;
    }
  }
  @media (min-width: 64rem) {
    .gallery--masonry {
      columns: 3;
    }
  }
  .gallery--masonry .gallery-item {
    break-inside: avoid;
    margin: 0 0 var(--space-sm);
  }

  .gallery--squares {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(min(10rem, 42vw), 1fr));
    gap: var(--space-sm) var(--space-xs);
  }
  .gallery--squares .gallery-item {
    margin: 0;
  }
  .gallery--squares :global(img.sq) {
    aspect-ratio: 1;
    object-fit: cover;
    inline-size: 100%;
  }
  .swatch-name {
    padding-block-start: var(--space-2xs);
    font-size: var(--text-xs);
    letter-spacing: var(--track-caps);
    text-transform: uppercase;
    color: var(--muted);
  }

  /* rows — justified: every image keeps its aspect, rows share a height */
  .gallery--rows {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-xs);
  }
  .gallery--rows::after {
    content: ""; /* keeps the last row at natural size instead of stretching */
    flex: 999999 1 0%;
  }
  .gallery--rows .gallery-item {
    margin: 0;
    flex: calc(var(--ar, 1.5) * 100) 1 calc(var(--ar, 1.5) * clamp(8rem, 16vw, 13rem));
    min-inline-size: 0;
  }
  .gallery--rows .gallery-item a {
    block-size: 100%;
  }
  .gallery--rows :global(img) {
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
    aspect-ratio: var(--ar, 1.5);
  }

  /* mosaic — mixed-size feature grid */
  .gallery--mosaic {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    grid-auto-rows: clamp(7rem, 24vw, 11rem);
    grid-auto-flow: dense;
    gap: var(--space-xs);
  }
  @media (min-width: 64rem) {
    .gallery--mosaic {
      grid-template-columns: repeat(4, 1fr);
    }
  }
  .gallery--mosaic .gallery-item {
    margin: 0;
  }
  .gallery--mosaic .gallery-item:nth-child(8n + 1) {
    grid-column: span 2;
    grid-row: span 2;
  }
  .gallery--mosaic .gallery-item:nth-child(8n + 6) {
    grid-row: span 2;
  }
  .gallery--mosaic .gallery-item a {
    block-size: 100%;
  }
  .gallery--mosaic :global(img) {
    inline-size: 100%;
    block-size: 100%;
    object-fit: cover;
  }

  /* separated interactive strip */
  .wide-views {
    margin-block-start: var(--space-lg);
  }
  .wide-views-label {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    color: var(--accent);
    margin-block-end: var(--space-sm);
  }
  .wide-views-rule {
    flex: 1;
    border-block-end: 1px solid var(--line);
  }
  .wide-views-grid {
    display: grid;
    gap: var(--space-md);
  }
  @media (min-width: 48rem) {
    .wide-views-grid {
      grid-template-columns: repeat(auto-fit, minmax(20rem, 1fr));
    }
  }

  .gallery-item a {
    display: block;
    outline-offset: 2px;
  }
  .gallery-item :global(img) {
    inline-size: 100%;
    background: var(--wash); /* tinted box while the image decodes — no hard pop-in */
    transition: opacity var(--dur-fast) ease, scale var(--dur-slow) var(--ease-out);
  }
  .gallery-item > a:hover :global(img) {
    opacity: 0.92;
  }

  /* scroll reveal */
  .gallery-item[data-reveal] {
    opacity: 0;
    translate: 0 14px;
    transition:
      opacity var(--dur-slow) var(--ease-out) var(--stagger, 0ms),
      translate var(--dur-slow) var(--ease-out) var(--stagger, 0ms);
  }
  .gallery-item[data-reveal].in-view {
    opacity: 1;
    translate: 0 0;
  }
</style>

<script>
  import PhotoSwipeLightbox from "photoswipe/lightbox";
  import "photoswipe/style.css";

  const lightbox = new PhotoSwipeLightbox({
    gallery: "[data-pswp-gallery]",
    children: "a[data-pswp-width]",
    pswpModule: () => import("photoswipe"),
    bgOpacity: 0.96,
    padding: { top: 24, bottom: 24, left: 12, right: 12 },
  });
  lightbox.init();
</script>
