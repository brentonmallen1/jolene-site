---
interface Props {
  email: string;
  linkedin: string;
  name: string;
}
const { email, linkedin, name } = Astro.props;
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <span class="footer-spacer" aria-hidden="true"></span>
  <div class="footer-contact">
    <a
      class="footer-linkedin"
      href={linkedin}
      target="_blank"
      rel="noreferrer noopener"
      aria-label="LinkedIn profile"
    >
      <svg aria-hidden="true" viewBox="0 0 24 24" width="15" height="15" fill="currentColor">
        <path d="M4.98 3.5C4.98 4.88 3.87 6 2.5 6S0 4.88 0 3.5 1.12 1 2.5 1s2.48 1.12 2.48 2.5ZM.22 8.16h4.56V23H.22V8.16Zm7.34 0h4.37v2.02h.06c.61-1.15 2.1-2.37 4.32-2.37 4.62 0 5.47 3.04 5.47 6.99V23h-4.55v-7.21c0-1.72-.03-3.93-2.4-3.93-2.4 0-2.77 1.87-2.77 3.8V23H7.56V8.16Z" />
      </svg>
    </a>
    <a class="footer-email" href={`mailto:${email}`}>{email}</a>
  </div>
  <p class="footer-copy">© {year} {name}</p>
</footer>

<style>
  :global(body) {
    /* keep page content clear of the fixed bar */
    padding-block-end: var(--footer-h);
  }
  .site-footer {
    position: fixed;
    inset: auto 0 0 0;
    z-index: 18;
    block-size: var(--footer-h);
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    align-items: center;
    padding-inline: var(--gutter);
    background: color-mix(in oklab, var(--paper) 90%, transparent);
    backdrop-filter: blur(10px);
    border-block-start: 1px solid var(--line);
  }
  .footer-contact {
    display: grid;
    justify-items: center;
    gap: 0.15rem;
  }
  .footer-linkedin {
    display: grid;
    place-items: center;
    inline-size: 2rem;
    block-size: 1.75rem; /* WCAG 2.2 target size: >=24px */
    color: var(--muted);
    transition: color var(--dur-fast) ease;
  }
  .footer-linkedin:hover {
    color: var(--accent);
  }
  .footer-email {
    font-size: var(--text-xs);
    letter-spacing: 0.06em;
    color: var(--muted);
    text-decoration: none;
    transition: color var(--dur-fast) ease;
  }
  .footer-email:hover {
    color: var(--ink);
  }
  .footer-copy {
    justify-self: end;
    font-size: var(--text-xs);
    color: var(--muted);
  }
  @media (max-width: 47.9rem) {
    .footer-spacer,
    .footer-copy {
      display: none;
    }
    .site-footer {
      grid-template-columns: 1fr;
      justify-items: center;
    }
  }
</style>
