---
interface Props {
  number: string;
  title: string;
}
const { number, title } = Astro.props;
---

<h2 class="section-heading" data-reveal>
  <span class="num">{number}</span>
  <span class="word">{title}</span>
</h2>

<style>
  .section-heading {
    display: flex;
    align-items: baseline;
    gap: 0.75em;
    font-size: var(--text-lg);
    font-weight: 420;
    letter-spacing: var(--track-caps);
    text-transform: uppercase;
    margin-block-end: var(--space-md);
  }
  .num {
    font-weight: 300;
    color: var(--accent);
  }
  .section-heading::after {
    content: "";
    flex: 1;
    block-size: 1px;
    background: linear-gradient(to right, var(--accent-2) 0 2.5rem, var(--line) 2.5rem);
    translate: 0 -0.35em;
  }
</style>
